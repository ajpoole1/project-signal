EODHD_API_KEY=your_eodhd_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Airflow
# Generate fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_key_here

# Database — two roles, one per DB (Q12): airflow_app owns the airflow metadata DB,
# signal_app owns the signal data DB. Role + DB names are hardcoded in docker-compose;
# only the two passwords are injected. On the AWS box these come from Secrets Manager
# via deploy.sh's shim; locally, set each to the password of the local role that owns
# that database (a single local superuser used for both is fine for dev).
AIRFLOW_DB_PASSWORD=airflow
SIGNAL_DB_PASSWORD=airflow
# SIGNAL_DB_USER defaults to signal_app; uncomment to point scripts at a different
# local role name.
# SIGNAL_DB_USER=signal_app
